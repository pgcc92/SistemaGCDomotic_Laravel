APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB local (solo para auth/config del dashboard; NO es la BD remota de negocio)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"

# GC SaaS / Multi-tenant
CONFIG_STORE_DRIVER=file
TENANT_MODE=single
TENANT_DEFAULT=default
TENANT_BASE_DOMAIN=

# Branding defaults (RGB espacio-separado)
BRANDING_PRIMARY_RGB="79 70 229"
BRANDING_SECONDARY_RGB="14 165 233"
BRANDING_FONT_FAMILY="Figtree"
BRANDING_DARK_MODE_ENABLED=true

# API remota (capa de servicios para BD externa)
REMOTE_API_BASE_URL=http://localhost:8001
REMOTE_API_KEY=
REMOTE_API_TIMEOUT=10

# Imágenes persistentes: en EasyPanel/Hostinger debe apuntar a un volumen montado.
# Si no se define, usa la carpeta local storage/ del proyecto.
GC_UPLOAD_ROOT=
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
