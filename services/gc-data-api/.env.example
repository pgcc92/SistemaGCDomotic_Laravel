APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gcdomoticbot
DB_USERNAME=postgres
DB_PASSWORD=

# Seguridad API (recomendado: Bearer token; también acepta X-API-Key)
GC_API_TOKEN=
GC_API_KEY_HASH_DRIVER=sha256
GC_AUTH_LOGIN_PER_MINUTE=30

# Multi-tenant por subdominio
TENANT_MODE=subdomain
TENANT_DEFAULT=default
TENANT_BASE_DOMAIN=midominio.com

# Mapeo de tablas (ajustar según tu esquema real)
GC_TABLE_CLIENTES=clientes
GC_TABLE_TICKETS=tickets
GC_TABLE_VENTAS=ventas
GC_TABLE_PRODUCTOS=productos
GC_TABLE_STOCK_SUCURSAL=stock_sucursal
GC_TABLE_MOVIMIENTOS_STOCK=movimientos_stock
GC_TABLE_VENTA_ITEMS=venta_items
GC_TABLE_PAGOS=pagos
GC_TABLE_COMISIONES=comisiones
GC_TABLE_COMISION_REGLAS=comision_reglas
GC_TABLE_DOCUMENTO_SERIES=documento_series
GC_TABLE_TIPO_CAMBIO=tipo_cambio
GC_TABLE_MENSAJES_BUFFER=mensajes_buffer

GC_DEFAULT_NV_SERIE=NV01
GC_IGV_DEFAULT=18.00

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
